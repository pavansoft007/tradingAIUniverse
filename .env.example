# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=TradingAI Universe
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Internal API (your own backend, if any) ───────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ── Angel One SmartAPI ────────────────────────────────────────────────────────
# Base URL — do not change unless Angel One publishes a new endpoint
NEXT_PUBLIC_ANGEL_ONE_BASE_URL=https://apiconnect.angelone.in

# Your SmartAPI key from https://smartapi.angelone.in/
# This key is embedded in every request as X-PrivateKey.
# It identifies your app, NOT the end user. Safe to expose client-side.
NEXT_PUBLIC_ANGEL_ONE_API_KEY=your_smartapi_key_here

# ── Feature Flags ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_AI_SIGNALS=true
NEXT_PUBLIC_ENABLE_PAPER_TRADING=true
